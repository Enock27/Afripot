{
  "name": "restaurant-gem",
  "type": "javascript",
  "main": "dist/server/index.js",
  "build": {
    "command": "npm run build",
    "cwd": "."
  },
  "env": {
    "production": {
      "routes": [
        {
          "pattern": "restaurant-gem.pages.dev",
          "zone_name": "pages.dev"
        }
      ]
    }
  }
}
